# iris configuration. Copy to .env and fill in. .env is gitignored.

# ============================================================================
# Memory backend
# ============================================================================
# Selects how handovers are stored. One of:
#   markdown  — handovers/handover_NNN.md (zero external deps)
#   obsidian  — notes inside an obsidian vault at $OBSIDIAN_VAULT
MEMORY_BACKEND=markdown

# Only used when MEMORY_BACKEND=obsidian. Must point at an existing vault.
# Example: OBSIDIAN_VAULT=/home/you/Obsidian/work-vault
OBSIDIAN_VAULT=

# Per-project namespace inside the vault, so multiple iris projects can share
# one OBSIDIAN_VAULT without mixing handover chains: handovers land under
# work/handovers/<IRIS_PROJECT>/. Defaults to the project directory name —
# set this only to disambiguate two projects with the same folder name.
# (The markdown backend is already isolated per project; this is obsidian-only.)
IRIS_PROJECT=

# ============================================================================
# Backlog + plan-ahead queue
# ============================================================================
PLAN_PATH=docs/plan.md

# Plan-ahead queue: jot future tasks into this file while a /run loop works the
# current task; the loop drains it into the backlog between tasks. (Swarm width
# is auto-decided from the work + machine — there is no width knob.)
NEXT_PATH=docs/next.md

# ============================================================================
# Project areas
# ============================================================================
# Directory the /new-task command scaffolds into. Defaults to "Projects".
# Rename to whatever fits your repo: "Tasks", "Work", "Initiatives".
PROJECTS_DIR=Projects

# ============================================================================
# Stale-reference scanner ignore-list
# ============================================================================
# Colon-separated path prefixes the handover stale-reference scanner skips.
# Useful when your repo contains nested submodules or untracked vendored
# directories.
# Example: IRIS_STALE_PATH_IGNORE=vendor/:third_party/
IRIS_STALE_PATH_IGNORE=

# ============================================================================
# Autonomous takeover + second brain
# ============================================================================
# Auto-capture your prompts so the second brain can distil them into instincts.
# Off by default — the brain still learns from /takeover's own observe/reward.
# To enable: wire .claude/hooks/brain-observe.sh as a UserPromptSubmit hook and
# set this to "on". Captured prompts stay in the gitignored .iris-state/.
BRAIN_OBSERVE=off

# Where the global (cross-project) second-brain tier lives. Defaults to ~/.iris.
# IRIS_HOME=~/.iris

# ============================================================================
# Claude binary (rarely overridden)
# ============================================================================
# CLAUDE_BIN=claude

# ============================================================================
# Integrations (all optional — each adapter loads only if its config is set)
# ============================================================================

# --- Slack (reference adapter) ----------------------------------------------
# Outbound webhook for notifications. Leave blank to disable.
SLACK_WEBHOOK_URL=

# Bidirectional Socket Mode bot. Required for scripts/slackbot-start.sh.
# Create app at api.slack.com/apps → enable Socket Mode → install to workspace.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
# Restrict the bot to one channel (recommended). Empty = listen everywhere.
SLACK_CHANNEL_ID=

# --- Discord (stub adapter, not wired) --------------------------------------
# DISCORD_BOT_TOKEN=
# DISCORD_CHANNEL_ID=

# --- Generic webhook (stub adapter, not wired) ------------------------------
# WEBHOOK_URL=
# WEBHOOK_SECRET=
