# iris configuration. Copy to .env and fill in. .env is gitignored.

# ============================================================================
# Memory backend
# ============================================================================
# Selects how handovers are stored. One of:
#   markdown  — handovers/handover_NNN.md (zero external deps)
#   obsidian  — notes inside an obsidian vault at $OBSIDIAN_VAULT
MEMORY_BACKEND=markdown

# Only used when MEMORY_BACKEND=obsidian. Must point at an existing vault.
# Example: OBSIDIAN_VAULT=/home/you/Obsidian/work-vault
OBSIDIAN_VAULT=

# ============================================================================
# Backlog file
# ============================================================================
PLAN_PATH=docs/plan.md

# ============================================================================
# Project areas
# ============================================================================
# Directory the /new-task command scaffolds into. Defaults to "Tasks".
# Rename to whatever fits your repo: "Projects", "Work", "Initiatives".
PROJECTS_DIR=Tasks

# ============================================================================
# Stale-reference scanner ignore-list
# ============================================================================
# Colon-separated path prefixes the handover stale-reference scanner skips.
# Useful when your repo contains nested submodules or untracked vendored
# directories.
# Example: IRIS_STALE_PATH_IGNORE=vendor/:third_party/
IRIS_STALE_PATH_IGNORE=

# ============================================================================
# Claude binary (rarely overridden)
# ============================================================================
# CLAUDE_BIN=claude

# ============================================================================
# Integrations (all optional — each adapter loads only if its config is set)
# ============================================================================

# --- Slack (reference adapter) ----------------------------------------------
# Outbound webhook for notifications. Leave blank to disable.
SLACK_WEBHOOK_URL=

# Bidirectional Socket Mode bot. Required for scripts/slackbot-start.sh.
# Create app at api.slack.com/apps → enable Socket Mode → install to workspace.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
# Restrict the bot to one channel (recommended). Empty = listen everywhere.
SLACK_CHANNEL_ID=

# --- Discord (stub adapter, not wired) --------------------------------------
# DISCORD_BOT_TOKEN=
# DISCORD_CHANNEL_ID=

# --- Generic webhook (stub adapter, not wired) ------------------------------
# WEBHOOK_URL=
# WEBHOOK_SECRET=
